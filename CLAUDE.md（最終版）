## DBスキーマ

### cases（案件テーブル）

```sql
create table cases (
  id uuid default gen_random_uuid() primary key,
  store_name text not null,
  instagram_account text,
  area text,
  assignee text,
  notes text,
  status text not null default 'active'
    check (status in ('active', 'completed', 'archived')),
  current_phase text not null default 'sales'
    check (current_phase in ('sales', 'collection', 'production', 'review', 'instagram')),
  current_step integer not null default 1,
  step_completed jsonb not null default '{}',
  drive_folder_url text,
  store_page_url text,
  job_page_url text,
  created_at timestamptz default now() not null,
  updated_at timestamptz default now() not null
);

create index cases_status_idx on cases(status);
create index cases_created_at_idx on cases(created_at desc);
```

### generated_content（AI生成結果テーブル）

```sql
create table generated_content (
  id uuid default gen_random_uuid() primary key,
  case_id uuid references cases(id) on delete cascade not null,
  content_type text not null
    check (content_type in ('store_intro', 'job_text', 'instagram_prompt')),
  input_data jsonb not null,
  output_text text not null,
  created_at timestamptz default now() not null
);

create index generated_content_case_id_idx on generated_content(case_id);
```

